{
  "expo": {
    "name": "Beam",
    "slug": "beam-parent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1787A6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.beam.parent",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "beam"
            ]
          }
        ],
        "NSLocationWhenInUseUsageDescription": "Beam uses your location to show activities near you.",
        "NSLocationAlwaysUsageDescription": "Beam uses your location to show activities near you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#1787A6"
      },
      "package": "com.beam.parent",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "beam"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#1787A6"
        }
      ],
      "expo-secure-store",
      "expo-video",
      "expo-location"
    ],
    "scheme": "beam",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ef7c21a5-cd69-473f-9018-4c16a40f8653"
      }
    }
  }
}
