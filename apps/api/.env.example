NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Transaction pooler (port 6543)
# DEV:  use your beam-dev Supabase project
# PROD: use your beam-prod Supabase project
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
# DEV:  beam-dev project keys
# PROD: beam-prod project keys
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Use DIFFERENT secrets for dev and prod
JWT_SECRET=change-me-to-a-random-32-character-minimum-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Optional ──────────────────────────────────────────────────────────────────
# Upstash → https://console.upstash.com
UPSTASH_REDIS_URL=rediss://default:...@....upstash.io:6379

# Razorpay → https://dashboard.razorpay.com/app/keys
# DEV:  use rzp_test_* keys
# PROD: use rzp_live_* keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Resend → https://resend.com/api-keys
RESEND_API_KEY=re_...

EXPO_ACCESS_TOKEN=
META_WHATSAPP_TOKEN=
