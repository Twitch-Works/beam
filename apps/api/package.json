    "db:seed-user": "tsx src/db/seed-test-user.ts"
  },
  "dependencies": {
    "@beam/schemas": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^4.26.2",
    "ioredis": "^5.3.2",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.3",
    "razorpay": "^2.9.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
