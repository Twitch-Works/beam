{
  "expo": {
    "name": "Beam Teacher",
    "slug": "beam-teacher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1787A6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.beam.teacher"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#1787A6"
      },
      "package": "com.beam.teacher"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#1787A6"
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "beam",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "beam-teacher-app"
      }
    }
  }
}
