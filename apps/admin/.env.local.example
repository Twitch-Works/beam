# Beam Admin — local environment
# Copy to .env.local and fill in values

NEXT_PUBLIC_APP_MODE=development

# API server URL
# LOCAL:  http://localhost:3000  (run `pnpm --filter=api dev`)
# DEV:    https://beam-api-git-dev-<team>.vercel.app  (Vercel Preview deployment)
# PROD:   https://beam-api-xi.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase — Project Settings > API
# DEV:  beam-dev project keys
# PROD: beam-prod project keys
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
